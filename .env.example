# Global Environment Variables
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Database & Caching
MONGODB_URI=mongodb://127.0.0.1:27017/rmf-platform
REDIS_URL=redis://127.0.0.1:6379

# Upload Storage
# Preferred for production media storage. Provide either the JSON env or the split email/key envs.
GOOGLE_CLOUD_STORAGE_BUCKET=your-gcs-bucket
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CLOUD_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLOUD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_CLOUD_STORAGE_PUBLIC_URL_PREFIX=https://storage.googleapis.com/your-gcs-bucket
GOOGLE_CLOUD_STORAGE_PREDEFINED_ACL=
GOOGLE_CLOUD_STORAGE_CACHE_CONTROL=public, max-age=31536000, immutable

# Optional S3/R2 fallback if Google Cloud Storage is not configured.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_PUBLIC_URL_PREFIX=

# Security
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
INTERNAL_SERVICE_SECRET=change-me-to-a-strong-random-secret-for-inter-service-auth

# Integrations
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
PAYPACK_CLIENT_ID=your_paypack_client_id
PAYPACK_CLIENT_SECRET=your_paypack_client_secret
PAYPACK_BASE_URL=https://payments.paypack.rw/api
PAYPACK_WEBHOOK_MODE=development
PAYPACK_WEBHOOK_SECRET=your_paypack_webhook_secret
PAYPACK_AUTO_CONFIRM=false
PAYPACK_PLATFORM_PHONE=0780000000
ALLOW_LEGACY_PAYMENT_GATEWAYS=false
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_USER_ID=your_mtn_user_id
MTN_MOMO_API_SECRET=your_mtn_api_secret
MTN_MOMO_TARGET_ENV=sandbox
AIRTEL_MONEY_API_KEY=your_airtel_api_key
AIRTEL_MONEY_SECRET=your_airtel_secret
AIRTEL_MONEY_TARGET_ENV=sandbox
AFRICAS_TALKING_API_KEY=your_africas_talking_key
SENDGRID_API_KEY=your_sendgrid_key
MAPBOX_ACCESS_TOKEN=your_secret_or_service_mapbox_token
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_public_mapbox_token_for_frontend_tiles
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_public_mapbox_token_for_mobile_map_tiles
OPENCAGE_API_KEY=your_opencage_api_key
GEOCODER_PROVIDER=auto
GEOCODING_TIMEOUT_MS=3000
GEOCODING_CACHE_TTL_MS=86400000

# Local Development SMTP (MailDev)
SMTP_HOST=localhost
SMTP_PORT=1025
