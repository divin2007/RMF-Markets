{
  "name": "rmf-platform",
  "packageManager": "npm@10.2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "npm run build --workspace @rmf/database && turbo run dev --concurrency=20 --continue=always --env-mode=loose",
    "wait-for-services": "node scripts/wait-for-services.js",
    "seed": "npm run seed --workspace market-service",
    "clear-db": "node apps/market-service/scripts/clear-db.js",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.39.4",
    "turbo": "^2.9.8"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@rmf/database": "^0.1.0",
    "@rmf/location": "^0.1.0",
    "@rmf/shared-types": "^0.1.0",
    "@rmf/shared-utils": "^0.1.0",
    "ansis": "^4.2.0",
    "bcrypt": "^6.0.0",
    "chokidar": "^4.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "mongoose": "^9.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "readdirp": "^4.1.2"
  },
  "overrides": {
    "postcss": "8.5.14",
    "ws": "8.20.1",
    "brace-expansion@5": "5.0.6",
    "engine.io": {
      "ws": "8.20.1"
    },
    "engine.io-client": {
      "ws": "8.20.1"
    },
    "next@16.2.6": {
      "postcss": "8.5.14"
    }
  }
}
